@model List<MobileCarRecoverySystem.Models.RecoveryCase>

<h2>Mobile Car Recovery Management System</h2>

<p>
    <a href="/Recovery/Create">Add Recovery Case</a> |
    <a href="/Recovery/Search">Search Recovery Case</a>
</p>

<table border="1" cellpadding="8">
    <tr>
        <th>Case ID</th>
        <th>Customer Name</th>
        <th>Phone Number</th>
        <th>Vehicle Registration</th>
        <th>Vehicle Model</th>
        <th>Breakdown Location</th>
        <th>Status</th>
        <th>Action</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.CaseId</td>
            <td>@item.CustomerName</td>
            <td>@item.PhoneNumber</td>
            <td>@item.VehicleRegistration</td>
            <td>@item.VehicleModel</td>
            <td>@item.BreakdownLocation</td>
            <td>@item.RecoveryStatus</td>
            <td>
                <form method="post" action="/Recovery/Delete">
                    <input type="hidden" name="registration" value="@item.VehicleRegistration" />
                    <button type="submit">Delete</button>
                </form>
            </td>
        </tr>
    }
</table>