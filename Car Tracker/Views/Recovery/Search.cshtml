@model MobileCarRecoverySystem.Models.RecoveryCase

<h2>Search Recovery Case</h2>

<form method="post">
    <label>Enter Vehicle Registration:</label><br />
    <input type="text" name="registration" />
    <button type="submit">Search</button>
</form>

<br />

@if (Model != null)
{
    <h3>Search Result</h3>
    <p><strong>Case ID:</strong> @Model.CaseId</p>
    <p><strong>Customer Name:</strong> @Model.CustomerName</p>
    <p><strong>Phone Number:</strong> @Model.PhoneNumber</p>
    <p><strong>Vehicle Registration:</strong> @Model.VehicleRegistration</p>
    <p><strong>Vehicle Model:</strong> @Model.VehicleModel</p>
    <p><strong>Breakdown Location:</strong> @Model.BreakdownLocation</p>
    <p><strong>Status:</strong> @Model.RecoveryStatus</p>
}
else if (Context.Request.Method == "POST")
{
    <p style="color:red">No recovery case found.</p>
}

<p><a href="/Recovery/Index">Back to List</a></p>